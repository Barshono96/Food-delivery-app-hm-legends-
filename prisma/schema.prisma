// ------------------------------------ product model start --------------------------------

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

model Product {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  name         String?
  price        Float        @default(0)
  sku          String?      @unique
  stock        Int?         @default(0)
  stock_status StockStatus? @default(IN_STOCK)
  image        String?
  order_items  OrderItem[]

  @@index([user_id])
  @@index([stock_status])
  @@index([sku])
  @@index([name])
  @@map("products")
}

// ------------------------------------ product model end --------------------------------

// ------------------------------------ order model start --------------------------------

enum OrderStatus {
  PENDING
  APPROVED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

model Order {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  status         OrderStatus? @default(PENDING)
  total_amount   Float        @default(0)
  total_quantity Int          @db.Integer

  user_id String
  user    User?  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  order_items OrderItem[]
  invoice     Invoice?
  delivery    Delivery?

  @@index([user_id])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  quantity   Int      @db.Integer
  price      Float    @default(0)
  product_id String?
  product    Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  order_id String
  order    Order? @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([quantity])
  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

// ------------------------------------ order model end --------------------------------

// ------------------------------------ invoice model start --------------------------------

model Invoice {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  paid_at DateTime?

  sku        String?       @unique
  status     InvoiceStatus @default(PENDING)
  order_id   String        @unique
  order      Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)
  creator_id String
  creator    User?         @relation("InvoiceCreator", fields: [creator_id], references: [id], onDelete: Cascade)

  receiver_id String
  receiver    User?   @relation("InvoiceReceiver", fields: [receiver_id], references: [id], onDelete: Cascade)
  url         String?

  @@index([order_id])
  @@index([status])
  @@index([creator_id])
  @@index([receiver_id])
  @@index([sku])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
}

// ------------------------------------ invoice model end --------------------------------

// ------------------------------------ Delivery model start ------------------------------

enum DeliveryStatus {
  ASSIGNED
  STARTED
  COMPLETED
}

model Delivery {
  id         String          @id @default(cuid())
  created_at DateTime        @default(now())
  updated_at DateTime        @default(now())
  status     DeliveryStatus? @default(ASSIGNED)
  order_id   String          @unique
  order      Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)

  driver_id String
  driver    User?  @relation("DeliveryDriver", fields: [driver_id], references: [id], onDelete: Cascade)

  admin_id      String
  admin         User?   @relation("DeliveryAdmin", fields: [admin_id], references: [id], onDelete: Cascade)
  note          String?
  signature_url String?

  received_at  DateTime?
  delivered_at DateTime?

  @@index([order_id])
  @@index([status])
  @@index([driver_id])
  @@index([admin_id])
  @@map("deliveries")
  deliveryTrackings DeliveryTracking[]
}

model DeliveryTracking {
  id            String   @id @default(cuid())
  delivery_id   String   @unique
  delivery      Delivery @relation(fields: [delivery_id], references: [id], onDelete: Cascade)
  driver_id     String
  driver        User     @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  current_lat   Float?
  current_lon   Float?
  // Checkpoints Coordinates
  checkpoint1_lat Float?
  checkpoint1_lon Float?
  checkpoint2_lat Float?
  checkpoint2_lon Float?
  checkpoint3_lat Float?
  checkpoint3_lon Float?
  destination_lat Float?
  destination_lon Float?
  // ETA (Estimated Times)
  eta_checkpoint1 DateTime?
  eta_checkpoint2 DateTime?
  eta_checkpoint3 DateTime?
  eta_destination DateTime?
  // Reached Times
  reached_checkpoint1 DateTime?
  reached_checkpoint2 DateTime?
  reached_checkpoint3 DateTime?
  reached_destination DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  delivery_reached    Boolean  @default(false)

  @@index([driver_id])
  @@map("delivery_tracking")
}


// ------------------------------------ Delivery model end --------------------------------
